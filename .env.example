# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Database (also set in docker-compose, listed here for reference)
POSTGRES_USER=clauseguard
POSTGRES_PASSWORD=clauseguard
POSTGRES_DB=clauseguard
DATABASE_URL=postgresql+asyncpg://clauseguard:clauseguard@db:5432/clauseguard

# Auth (for demo)
JWT_SECRET=clauseguard-hackathon-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# App
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# TrustFoundry — verified legal search & reasoning (hackathon sponsor)
# Provides verified citations from 14M+ US laws, regulations, and cases.
# Get API key at: https://dashboard.trustfoundry.ai (Developers tab)
TRUSTFOUNDRY_API_KEY=api_your_key_here
TRUSTFOUNDRY_API_URL=https://api.trustfoundry.ai
TRUSTFOUNDRY_ENABLED=true
